local function ProcessCommand(cmd)
    cmd = string.match(cmd, "^%s*(.-)%s*$") -- trim
    local cmdLower = string.lower(cmd)

    if cmdLower == "cmds" then
        ShowCommandsGUI()
        return
    end

    -- JUMP
    if cmdLower == "jump" then
        local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
        print("[Alt Controller] Jumped!")
        return
    end
    
    -- STOP
    if cmdLower == "stop" then
        StopAllActions()
        print("[Alt Controller] Stopped all actions.")
        return
    end

    -- RESET (respawns the character)
    if cmdLower == "reset" then
        StopAllActions()
        if LocalPlayer.Character then
            local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.Health = 0
            end
        end
        print("[Alt Controller] Resetting character...")
        return
    end

    -- CHAT
    if string.sub(cmdLower, 1, 4) == "chat" then
        local chatMsg = string.match(string.sub(cmd, 5), "^%s*(.-)%s*$")
        if chatMsg and chatMsg ~= "" then
            local TextChatService = game:GetService("TextChatService")
            local ReplicatedStorage = game:GetService("ReplicatedStorage")
            if TextChatService and TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                pcall(function() TextChatService.TextChannels.RBXGeneral:SendAsync(chatMsg) end)
            elseif ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") then
                pcall(function() ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer(chatMsg, "All") end)
            end
            print("[Alt Controller] Said: " .. chatMsg)
        end
        return
    end

    -- BRING
    if string.sub(cmdLower, 1, 5) == "bring" then
        StopAllActions()
        print("[Alt Controller] Bringing alt to Main Account...")
        
        local leaderPlayer = FindPlayer(Config.MainAccount)
        if leaderPlayer and leaderPlayer.Character and leaderPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local leaderRoot = leaderPlayer.Character.HumanoidRootPart
            if LocalPlayer.Character then
                -- Add a small random offset so they don't all teleport into the exact same point and fling
                local offset = Vector3.new(math.random(-3, 3), 0, math.random(-3, 3))
                LocalPlayer.Character:PivotTo(leaderRoot.CFrame * CFrame.new(offset))
            end
        else
            print("[Alt Controller] Main Account not found or missing character.")
        end
        return
    end

    local function ParseArg(idx)
        return string.match(string.sub(cmd, idx), "^%s*(.-)%s*$")
    end

    local function ApplyModeSetup(modeName)
        CurrentMode = modeName
        local char = LocalPlayer.Character
