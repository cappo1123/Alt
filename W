                local dirOut = Vector3.new(xOffset, 0, zOffset).Unit
                if dirOut.Magnitude < 0.01 then dirOut = Vector3.new(0, 0, -1) end
                local layingCFrame = CFrame.lookAt(targetPos, targetPos + dirOut) * CFrame.Angles(math.rad(90), 0, 0)
                
                local bg = myRoot:FindFirstChildOfClass("BodyGyro")
                if bg then
                    bg.CFrame = layingCFrame
                else
                    bg = Instance.new("BodyGyro")
                    bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
                    bg.CFrame = layingCFrame
                    bg.Parent = myRoot
                end
                
                myHumanoid.PlatformStand = true
            end
            
            -- STRIKE EXECUTION BLOCK (Runs if this alt is currently striking)
            if ActiveStrikes[altIndexOffset] then
                local strikeData = ActiveStrikes[altIndexOffset]
                local tPlayer = Players:FindFirstChild(strikeData.targetName)
                local tRoot = tPlayer and tPlayer.Character and tPlayer.Character:FindFirstChild("HumanoidRootPart")
                
                if not tRoot or (tPlayer.Character:FindFirstChildOfClass("Humanoid") and tPlayer.Character:FindFirstChildOfClass("Humanoid").Health <= 0) then
                    -- Target dead or left, return
                    ActiveStrikes[altIndexOffset] = nil
                    local spinNode = myRoot:FindFirstChild("StrikeSpin")
                    if spinNode then spinNode:Destroy() end
                else
                    if strikeData.phase == "homing" then
                        -- Fly head first
                        local outDir = (tRoot.Position - myRoot.Position).Unit
                        local targetCFrame = CFrame.lookAt(myRoot.Position, tRoot.Position) * CFrame.Angles(math.rad(90), 0, 0)
                        
                        local bp = myRoot:FindFirstChildOfClass("BodyPosition")
                        if bp then 
                            -- Force them EXACTLY to the player's core to ensure collision
                            bp.Position = tRoot.Position
                        end
                        
                        local spinNode = myRoot:FindFirstChild("StrikeSpin")
                        if not spinNode then
                            spinNode = Instance.new("BodyAngularVelocity")
                            spinNode.Name = "StrikeSpin"
                            -- Spin on local Z axis using CFrame logic
                            -- To make a robust spin, we spin global axes but heavily
                            spinNode.AngularVelocity = outDir * 50 -- Spin around the flight axis
                            spinNode.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
                            spinNode.P = 1e5
                            spinNode.Parent = myRoot
                        else
                            spinNode.AngularVelocity = outDir * 50
                        end
                        -- Check if we hit them or timed out
                        strikeData.timer = strikeData.timer + dt
                        if (myRoot.Position - tRoot.Position).Magnitude < 4 or strikeData.timer > 3 then
                            -- Done! Let it snap back to UFO slot natively
                            ActiveStrikes[altIndexOffset] = nil
                            if spinNode then spinNode:Destroy() end
                        end
                    end
                end
            end
        end
        
        -- AUTO-JUMP OBSTACLE DETECTION
        -- Only apply if we are actually trying to walk, and not in floating modes
        if CurrentMode ~= "stack" and CurrentMode ~= "mech" and CurrentMode ~= "altmech" and CurrentMode ~= "elevator" and CurrentMode ~= "orbit" then
            if myHumanoid.MoveDirection.Magnitude > 0.1 then
                local currentPos = myRoot.Position
                local distMoved = Vector3.new(currentPos.X - lastPos.X, 0, currentPos.Z - lastPos.Z).Magnitude
                local expectedMove = myHumanoid.WalkSpeed * dt * 0.2 -- Give some grace period for slight turns/slopes
                
                if distMoved < expectedMove then
                    stuckTimer = stuckTimer + dt
                    if stuckTimer > 0.25 then -- If stuck for 0.25s, jump
                        myHumanoid.Jump = true
                        stuckTimer = 0
                    end
                else
                    stuckTimer = 0
                end
                lastPos = currentPos
            else
                stuckTimer = 0
                lastPos = myRoot.Position
            end
        end
    end)

elseif string.lower(LocalPlayer.Name) == string.lower(Config.MainAccount) then
    -- === MAIN ACCOUNT ===
    print("[Alt Controller] Main Account loaded.")
    local commandBarInput, toggleBar, hideBar = CreateCommandBar()
    
    -- Mech state for main account
    local mechActive = false
    local MECH_ELEVATION = 8 -- Studs above ground (room for legs below)
    local MECH_SPEED = 16
    local mechMoveDir = Vector3.zero
    
    -- Strike round-robin counter
    local nextStrikeAltIndex = 1
    
    -- OPT #4: Pre-create RaycastParams for mech ground detection (reused every frame)
    local mechRayParams = RaycastParams.new()
    mechRayParams.FilterType = Enum.RaycastFilterType.Exclude
    
    local function RefreshMechRayFilter()
        local filterList = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character then
                table.insert(filterList, p.Character)
            end
        end
        mechRayParams.FilterDescendantsInstances = filterList
    end
    RefreshMechRayFilter()
    
    local function ActivateMechOnSelf()
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if root and hum then
            hum.PlatformStand = true
            RefreshMechRayFilter()
            
            -- Clean up old ones first
            for _, obj in ipairs(root:GetChildren()) do
                if obj:IsA("BodyPosition") or obj:IsA("BodyGyro") then obj:Destroy() end
            end
            
            local bp = Instance.new("BodyPosition")
            bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bp.D = 2000
            bp.P = 50000
            bp.Position = root.Position + Vector3.new(0, MECH_ELEVATION, 0)
            bp.Parent = root
            
            local bg = Instance.new("BodyGyro")
            bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
            bg.CFrame = root.CFrame
            bg.Parent = root
            
            mechActive = true
            print("[Alt Controller] Mech: Owner elevated.")
        end
    end
    
    local function DeactivateMechOnSelf()
        mechActive = false
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if root then
            for _, obj in ipairs(root:GetChildren()) do
                if obj:IsA("BodyPosition") or obj:IsA("BodyGyro") then obj:Destroy() end
            end
            root.Anchored = false
        end
        if hum then
            hum.PlatformStand = false
            hum.WalkSpeed = 16
            hum.AutoRotate = true
            if hum:GetState() == Enum.HumanoidStateType.PlatformStanding then
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
        print("[Alt Controller] Mech: Owner grounded.")
    end
    
    -- Custom WASD movement for mech mode
    local lastRayFilterRefresh = 0
    
    RunService.Heartbeat:Connect(function(dt)
        if not mechActive then return end
        
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then return end
        
        local bp = root:FindFirstChildOfClass("BodyPosition")
        local bg = root:FindFirstChildOfClass("BodyGyro")
        if not bp or not bg then return end
        
        -- Throttle filter refresh to once per second instead of every frame
        if tick() - lastRayFilterRefresh > 1 then
            lastRayFilterRefresh = tick()
            RefreshMechRayFilter()
        end
        
        -- Read WASD input relative to camera
        -- Skip if command bar is focused so typing doesn't move the mech
        local moveDir = Vector3.zero
        if not commandBarInput:IsFocused() then
            local cam = workspace.CurrentCamera
            local camLook = cam.CFrame.LookVector
            local camRight = cam.CFrame.RightVector
            
            -- Flatten to XZ plane
            camLook = Vector3.new(camLook.X, 0, camLook.Z)
            if camLook.Magnitude > 0 then camLook = camLook.Unit end
            camRight = Vector3.new(camRight.X, 0, camRight.Z)
            if camRight.Magnitude > 0 then camRight = camRight.Unit end
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camLook end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camLook end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camRight end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camRight end
        end
        
        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit
        end
        
        -- OPT #4: Reuse RaycastParams (created once outside the loop)
        local rayOrigin = Vector3.new(bp.Position.X, bp.Position.Y + 20, bp.Position.Z)
        local rayResult = workspace:Raycast(rayOrigin, Vector3.new(0, -100, 0), mechRayParams)
        local groundY = rayResult and rayResult.Position.Y or 0
        
        -- Move horizontally
        local currentPos = bp.Position
        local newX = currentPos.X + (moveDir.X * MECH_SPEED * dt)
        local newZ = currentPos.Z + (moveDir.Z * MECH_SPEED * dt)
        local newY = groundY + MECH_ELEVATION
        
        bp.Position = Vector3.new(newX, newY, newZ)
        
        -- Face movement direction
        if moveDir.Magnitude > 0 then
            bg.CFrame = CFrame.lookAt(root.Position, root.Position + moveDir)
        end
        
        -- Keep PlatformStand active
        hum.PlatformStand = true
    end)
    
    -- ========== ELEVATOR STATE ==========
    local elevatorActive = false
    local carpetActive = false
    local ELEVATOR_RISE_SPEED = 3 -- Studs per second
    local CARPET_SPEED = 35
    local elevatorElevation = 0
    
    local function ActivateElevatorOnSelf(isCarpet)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if root and hum then
            hum.PlatformStand = true
            
            for _, obj in ipairs(root:GetChildren()) do
                if obj:IsA("BodyPosition") or obj:IsA("BodyGyro") then obj:Destroy() end
            end
            
            elevatorElevation = 0
            
            local bp = Instance.new("BodyPosition")
            bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bp.D = 2000
            bp.P = 50000
            -- Elevate slightly initially for carpet so you aren't stuck in ground
            bp.Position = root.Position + (isCarpet and Vector3.new(0, 5, 0) or Vector3.new(0, 0, 0))
            bp.Parent = root
            
            local bg = Instance.new("BodyGyro")
            bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
            bg.CFrame = root.CFrame
            bg.Parent = root
            
            if isCarpet then
                carpetActive = true
                print("[Alt Controller] Carpet: Flying mode engaged.")
            else
                elevatorActive = true
                print("[Alt Controller] Elevator: Rising!")
            end
        end
    end
    
    local function DeactivateElevatorOnSelf()
        elevatorActive = false
        carpetActive = false
        elevatorElevation = 0
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if root then
            for _, obj in ipairs(root:GetChildren()) do
                if obj:IsA("BodyPosition") or obj:IsA("BodyGyro") then obj:Destroy() end
            end
            root.Anchored = false
        end
        if hum then
            hum.PlatformStand = false
            hum.WalkSpeed = 16
            hum.AutoRotate = true
            hum:SetStateEnabled(Enum.HumanoidStateType.Seated, true) -- Re-enable sitting
            if hum:GetState() == Enum.HumanoidStateType.PlatformStanding or hum.Sit then
                hum.Sit = false
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
        print("[Alt Controller] Elevator/Carpet: Grounded.")
    end
    
    -- Elevator/Carpet Flight Heartbeat
    RunService.Heartbeat:Connect(function(dt)
        if not elevatorActive and not carpetActive then return end
        
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then return end
        
        local bp = root:FindFirstChildOfClass("BodyPosition")
        local bg = root:FindFirstChildOfClass("BodyGyro")
        if not bp or not bg then return end
        
        if elevatorActive then
            -- Slowly rise
            elevatorElevation = elevatorElevation + (ELEVATOR_RISE_SPEED * dt)
            
            if tick() - lastRayFilterRefresh > 1 then
                lastRayFilterRefresh = tick()
                RefreshMechRayFilter()
            end
            local rayOrigin = Vector3.new(root.Position.X, root.Position.Y + 20, root.Position.Z)
            local rayResult = workspace:Raycast(rayOrigin, Vector3.new(0, -100, 0), mechRayParams)
            local groundY = rayResult and rayResult.Position.Y or 0
            
            bp.Position = Vector3.new(root.Position.X, groundY + elevatorElevation + 3, root.Position.Z)
        
        elseif carpetActive then
            -- Free 3D flight (like noclip/admin fly)
            local moveDir = Vector3.zero
            local verticalDir = 0
            
            if not commandBarInput:IsFocused() then
                local cam = workspace.CurrentCamera
                local camLook = cam.CFrame.LookVector
                local camRight = cam.CFrame.RightVector
                
                -- Allow pitching up/down by using full LookVector instead of flattened XZ
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camLook end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camLook end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camRight end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camRight end
                
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then verticalDir = verticalDir + 1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then verticalDir = verticalDir - 1 end
            end
            
            if moveDir.Magnitude > 0 then
                moveDir = moveDir.Unit
            end
            
            local currentPos = bp.Position
            local newPos = currentPos + (moveDir * CARPET_SPEED * dt) + Vector3.new(0, verticalDir * CARPET_SPEED * dt, 0)
            bp.Position = newPos
            
            -- Rotate facing direction, but stay upright (don't pitch the body forward)
            if moveDir.Magnitude > 0 then
                local flatLook = Vector3.new(moveDir.X, 0, moveDir.Z)
                if flatLook.Magnitude > 0 then
                    bg.CFrame = CFrame.lookAt(root.Position, root.Position + flatLook)
                end
            end
        end
        
        hum.PlatformStand = true
    end)
    
    -- Clean up mech/elevator/carpet on death/respawn
    LocalPlayer.CharacterAdded:Connect(function()
        if mechActive then
            mechActive = false
            print("[Alt Controller] Mech: Respawned, mech deactivated.")
        end
        if elevatorActive or carpetActive then
            elevatorActive = false
            carpetActive = false
            elevatorElevation = 0
            print("[Alt Controller] Elevator/Carpet: Respawned, deactivated.")
        end
    end)
    
    -- Quick notification helper (shows text near command bar briefly)
    local function ShowNotification(msg)
        print("[Alt Controller] " .. msg)
        local screenGui = commandBarInput.Parent and commandBarInput.Parent.Parent
        if not screenGui then return end
        
        local existing = screenGui:FindFirstChild("AltNotify")
        if existing then existing:Destroy() end
        
        local label = Instance.new("TextLabel")
        label.Name = "AltNotify"
        label.Size = UDim2.new(0, 400, 0, 30)
        label.Position = UDim2.new(0.5, -200, 1, -140)
        label.BackgroundTransparency = 0.3
        label.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        label.TextColor3 = Color3.fromRGB(100, 255, 100)
        label.Font = Enum.Font.GothamMedium
        label.TextSize = 14
        label.Text = msg
        label.Parent = screenGui
        Instance.new("UICorner", label).CornerRadius = UDim.new(0, 6)
        
        task.delay(3, function()
            if label.Parent then label:Destroy() end
        end)
    end
    
    local function HandleMainCmd(cmdText)
        local cmdLower = string.lower(string.match(cmdText, "^%s*(.-)%s*$"))
        if cmdLower == "cmds" then
            ShowCommandsGUI()
            return true
        end
        
        -- Mech: activate on self AND broadcast to alts
        -- "mech p" = passive mode (alts form mech but you walk normally)
        if string.sub(cmdLower, 1, 8) == "alt mech" or string.sub(cmdLower, 1, 7) == "altmech" then
            DeactivateElevatorOnSelf() -- Clean up elevator if active
            DeactivateMechOnSelf() -- Stay grounded
            local argStr = cmdLower:find("^alt mech") and string.match(string.sub(cmdLower, 9), "^%s*(.-)%s*$") or string.match(string.sub(cmdLower, 8), "^%s*(.-)%s*$")
            if argStr and argStr ~= "" then
                ShowNotification("Alt Mech: Formation following " .. argStr)
            else
                ShowNotification("Alt Mech: Formation following behind you.")
            end
            return false -- Still broadcast to alts
        end
        
        if string.sub(cmdLower, 1, 4) == "mech" then
            DeactivateElevatorOnSelf() -- Clean up elevator if active
            if cmdLower ~= "mech p" then
                ActivateMechOnSelf()
            else
                DeactivateMechOnSelf() -- Make sure we're grounded
                ShowNotification("Mech Passive: Alts forming around you.")
            end
            return false -- Still broadcast to alts
        end
        
        -- Elevator, Carpet & UFO: activate on self AND broadcast to alts
        if cmdLower == "elevator" then
            DeactivateMechOnSelf()
            ActivateElevatorOnSelf(false)
            return false -- Still broadcast to alts
        end
        
        if cmdLower == "carpet" or cmdLower == "aladdin" then
            DeactivateMechOnSelf()
            ActivateElevatorOnSelf(true)
            return false
        end

        if cmdLower == "ufo" then
            DeactivateMechOnSelf()
            ActivateElevatorOnSelf(true)
            CurrentMode = "ufo" -- Track locally for the sit mechanic
            return false
        end
        

        
        -- Strike: intercept and assign a specific alt index
        if string.sub(cmdLower, 1, 6) == "strike" then
            local argStr = string.match(string.sub(cmdText, 7), "^%s*(.-)%s*$")
            if argStr and argStr ~= "" then
                -- Broadcast with the assigned alt index appended
                BroadcastCmdInvisible("strike " .. argStr .. " __idx" .. tostring(nextStrikeAltIndex))
                ShowNotification("Strike sent! Alt #" .. nextStrikeAltIndex .. " -> " .. argStr)
                nextStrikeAltIndex = nextStrikeAltIndex + 1
                if nextStrikeAltIndex > TotalAlts then
                    nextStrikeAltIndex = 1
                end
            end
            return true -- Already broadcast manually, don't double-send
        end
        
        -- Stop: deactivate everything AND broadcast to alts
        if cmdLower == "stop" then
            DeactivateMechOnSelf()
            DeactivateElevatorOnSelf()
            nextStrikeAltIndex = 1 -- Reset strike counter

            return false -- Still broadcast to alts
        end
        
        return false
    end
    
    commandBarInput.FocusLost:Connect(function(enterPressed)
        local cmd = commandBarInput.Text
        hideBar() -- Hide immediately so the UI is always snappy
        
        if enterPressed and cmd ~= "" then
            task.spawn(function()
                if not HandleMainCmd(cmd) then
                    BroadcastCmdInvisible(cmd)
                end
            end)
        end
    end)
else
    warn("[Alt Controller] Account (" .. LocalPlayer.Name .. ") not in config. Script dormant.")
end

