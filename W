local function CreateCommandBar()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AltControllerCommandBar"
    screenGui.ResetOnSpawn = false
    pcall(function() screenGui.Parent = CoreGui end)
    if not screenGui.Parent then
        screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 400, 0, 50)
    frame.Position = UDim2.new(0.5, -200, 1, 50)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BorderSizePixel = 0
    frame.Parent = screenGui

    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = Color3.fromRGB(100, 100, 100)
    stroke.Thickness = 1

    local textBox = Instance.new("TextBox")
    textBox.Size = UDim2.new(1, -20, 1, 0)
    textBox.Position = UDim2.new(0, 10, 0, 0)
    textBox.BackgroundTransparency = 1
    textBox.Font = Enum.Font.GothamMedium
    textBox.TextSize = 18
    textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    textBox.PlaceholderText = "Enter command (e.g. worm, stack, jump)..."
    textBox.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
    textBox.TextXAlignment = Enum.TextXAlignment.Left
    textBox.ClearTextOnFocus = true
    textBox.Parent = frame

    local isVisible = false

    local function ToggleCommandBar()
        isVisible = not isVisible
        if isVisible then
            frame:TweenPosition(UDim2.new(0.5, -200, 1, -100), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.3, true, function()
                textBox:CaptureFocus()
            end)
        else
            textBox:ReleaseFocus()
            frame:TweenPosition(UDim2.new(0.5, -200, 1, 50), Enum.EasingDirection.In, Enum.EasingStyle.Quart, 0.3, true, function()
                textBox.Text = ""
            end)
        end
    end

    local isHiding = false
    local function HideCommandBar()
        if isHiding then return end
        isHiding = true
        isVisible = false
        textBox:ReleaseFocus()
        frame:TweenPosition(UDim2.new(0.5, -200, 1, 50), Enum.EasingDirection.In, Enum.EasingStyle.Quart, 0.3, true, function()
            textBox.Text = ""
            isHiding = false
        end)
    end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed and not textBox:IsFocused() then return end
        if input.KeyCode == Enum.KeyCode.N and not textBox:IsFocused() then
            ToggleCommandBar()
        end
    end)

    return textBox, ToggleCommandBar, HideCommandBar
end

-- ==========================================
-- MAIN LOGIC
-- ==========================================

local isAlt = false
for altName, _ in pairs(Config.Alts) do
    if string.lower(altName) == string.lower(LocalPlayer.Name) then
        isAlt = true
        break
    end
end

if isAlt then
    -- === ALT ACCOUNT ===
    UpdateFollowTarget()
    print("[Alt Controller] Alt loaded: " .. LocalPlayer.Name)

    -- OPT #1: Cached character references (refreshed on CharacterAdded)
    local cachedRoot = nil
    local cachedHumanoid = nil
    
    local function RefreshCharacterCache()
        local char = LocalPlayer.Character
        if char then
            cachedRoot = char:FindFirstChild("HumanoidRootPart")
            cachedHumanoid = char:FindFirstChildOfClass("Humanoid")
        else
            cachedRoot = nil
            cachedHumanoid = nil
        end
    end
    RefreshCharacterCache()
    
    -- OPT #2: Cached bodyguard intruder scan results
    local cachedIntruders = {}
    local lastIntruderScan = 0
    
    local lastPos = Vector3.zero
    local stuckTimer = 0

    -- Collisions are disabled dynamically inside ProcessCommand when a mode starts
    LocalPlayer.CharacterAdded:Connect(function(character)
        task.wait(0.3)
        RefreshCharacterCache() -- OPT #1: Refresh cache on respawn
        if CurrentMode ~= "none" then
            for _, child in ipairs(character:GetChildren()) do
                if child:IsA("BasePart") then
                    -- Keep collisions ON for carpet and allfling modes so they hit people/world
                    if CurrentMode ~= "allfling" and CurrentMode ~= "carpet" then
                        child.CanCollide = false
                    end
                elseif child:IsA("Accessory") then
                    local handle = child:FindFirstChild("Handle")
                    if handle and handle:IsA("BasePart") then
                        if CurrentMode ~= "allfling" and CurrentMode ~= "carpet" then
                            handle.CanCollide = false
                        end
                    end
                end
            end
            
            -- Re-apply walk velocities if they respawn mid-formation
            local myHumanoid = character:FindFirstChildOfClass("Humanoid")
            if myHumanoid then
                -- Disable sitting
                myHumanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
                
                if CurrentMode == "vform" or CurrentMode == "circlein" or CurrentMode == "circleout" or CurrentMode == "spin" or CurrentMode == "army" or CurrentMode == "flank" or CurrentMode == "bodyguard" then
                    myHumanoid.WalkSpeed = 16
                end
            end
            
            -- Extra safety: Destroy SeatWelds instantly if they somehow get created
            character.ChildAdded:Connect(function(child)
                if child:IsA("Weld") and child.Name == "SeatWeld" then
                    task.wait()
                    child:Destroy()
                end
            end)
        end
    end)

    -- Invisible Executor Polling Listener
    if readfile and isfile then
        local lastTick = 0
        local lastCheck = 0
        
        RunService.Heartbeat:Connect(function()
            -- Reduced delay from 0.05 to 0.02 for ultra-responsive commands
            if tick() - lastCheck < 0.02 then return end
            lastCheck = tick()
            
            local s, out = pcall(function()
                if isfile(IPC_FILE) then return readfile(IPC_FILE) end
                return nil
            end)
            if s and out then
                local delim = string.find(out, "|", 1, true)
                if delim then
                    local cmdStr = string.sub(out, 1, delim - 1)
                    local tickStr = string.sub(out, delim + 1)
                    local parsedTick = tonumber(tickStr)
                    
                    if parsedTick and parsedTick > lastTick then
                        if lastTick == 0 and math.abs(tick() - parsedTick) > 5 then
                            lastTick = parsedTick 
                        else
                            lastTick = parsedTick
                            ProcessCommand(cmdStr)
                        end
                    end
                end
            end
        end)
    end

    -- Tracking variables for AllFling timeouts
    local lastModeTracked = "none"
    local allFlingBlacklist = {}
    local allFlingTarget = nil
    local allFlingTimer = 0
    
    -- Persistent targets for stalk mode
    local myPersistentTarget = nil
    
    -- Global override for assassin fling (Alt 1 only)
    -- (Declared at root)
    
    -- UFO and Strike Variables
    local ActiveStrikes = {} -- { [altIndex] = { targetName = string, timer = number, phase = string } }
    
    -- Haunted mode state
    local hauntedPhase = "idle" -- "idle" or "creeping"
    local hauntedTimer = math.random() * 5 + 2 -- Random initial delay (2-7 seconds)
    
    -- MOVEMENT LOGIC
    RunService.Heartbeat:Connect(function(dt)
        if CurrentMode ~= lastModeTracked then
            lastModeTracked = CurrentMode
            allFlingBlacklist = {}
            allFlingTarget = nil
            allFlingTimer = 0
            myPersistentTarget = nil
        end
        
        -- OPT #1: Use cached refs instead of FindFirstChild every frame
        local myRoot = cachedRoot
        local myHumanoid = cachedHumanoid
        
        -- Fallback: refresh cache if refs went stale
        if not myRoot or not myRoot.Parent or not myHumanoid or not myHumanoid.Parent then
            RefreshCharacterCache()
            myRoot = cachedRoot
            myHumanoid = cachedHumanoid
        end
        
        -- PREVENT RESPAWN BUGS: Do nothing if the character is dead or missing
        if not (myRoot and myHumanoid) or myHumanoid.Health <= 0 then return end
        
        local altIndexOffset = math.max(1, MyIndex - 1)
        
        -- ASSASSIN FLING OVERRIDE (Only Alt 1)
        if SingleFlingTarget and altIndexOffset == 1 then
            local tPlayer = FindPlayer(SingleFlingTarget)
            if tPlayer and tPlayer.Character and tPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local tRoot = tPlayer.Character.HumanoidRootPart
                -- Spin rapidly
                local bav = myRoot:FindFirstChild("FlingSpin")
                if not bav then
                    bav = Instance.new("BodyAngularVelocity")
                    bav.Name = "FlingSpin"
                    bav.AngularVelocity = Vector3.new(99999, 99999, 99999)
                    bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                    bav.P = math.huge
                    bav.Parent = myRoot
                end
                
                -- Teleport directly into target
                myRoot.CFrame = tRoot.CFrame
                return -- Skip formation logic completely
            else
                -- Target is dead or left, disable assassin mode
                SingleFlingTarget = nil
                local bav = myRoot:FindFirstChild("FlingSpin")
                if bav then bav:Destroy() end
            end
        elseif altIndexOffset == 1 and not SingleFlingTarget then
            local bav = myRoot:FindFirstChild("FlingSpin")
            if bav and CurrentMode ~= "allfling" and CurrentMode ~= "fling" then bav:Destroy() end
        end

        if CurrentMode == "none" then return end

        if CurrentMode == "scatter" then
            if ScatterTarget then
                if (myRoot.Position - ScatterTarget).Magnitude < 4 then
                    ScatterTarget = myRoot.Position + Vector3.new(math.random(-50, 50), 0, math.random(-50, 50))
                end
                myHumanoid:MoveTo(ScatterTarget)
                if math.random() < 0.02 then
                    myHumanoid.Jump = true
                end
            end
            return
        end

        local targetName = (CurrentMode == "worm") and MyFollowTarget or CommandLeader
        if not targetName then return end
        
        -- If this Alt is the designated leader for the formation, they should stand still, not chase themselves!
        if targetName == LocalPlayer.Name then return end

        local targetPlayer = Players:FindFirstChild(targetName)
        local targetRoot = targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local targetHumanoid = targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid")
        
        if not targetRoot then return end
        

        if CurrentMode == "worm" then
            local targetPos = targetRoot.Position
            local isJumping = targetHumanoid.Jump or (targetHumanoid:GetState() == Enum.HumanoidStateType.Jumping) or (targetHumanoid:GetState() == Enum.HumanoidStateType.Freefall)
            
            -- Only record crumbs if they moved enough (1.5 studs)
            if #TargetBreadcrumbs == 0 or (TargetBreadcrumbs[1].pos - targetPos).Magnitude > 1.5 then
                table.insert(TargetBreadcrumbs, 1, {pos = targetPos, jump = isJumping})
            else
                if isJumping and #TargetBreadcrumbs > 0 then
                    TargetBreadcrumbs[1].jump = true
                end
            end
            
            -- OPT #5: Tighter breadcrumb pruning — cap based on actual need
            local MaxCrumbs = math.max(20, TotalAlts * 4)
            while #TargetBreadcrumbs > MaxCrumbs do
                table.remove(TargetBreadcrumbs)
            end
            
            -- Find the correct crumb for THIS alt, based on their index
            -- At 1.5 studs per crumb minimum, spacing them by 1 crumb means ~1.5 to 2.5 studs spacing.
            local idealCrumbIndex = 2 -- Everyone stays exactly 2 crumbs behind the person directly in front of them
            idealCrumbIndex = math.clamp(idealCrumbIndex, 1, #TargetBreadcrumbs)

            local myCrumb = TargetBreadcrumbs[idealCrumbIndex]

            -- If there aren't enough crumbs generated yet for this alt to have its spaced out position, just wait.
            if not myCrumb then 
                myHumanoid:Move(Vector3.zero, false)
                return 
            end

            -- 3. Calculate 2D distance to our specific crumb
            local dist2DToCrumb = Vector2.new(myRoot.Position.X - myCrumb.pos.X, myRoot.Position.Z - myCrumb.pos.Z).Magnitude
            
            -- 4. Move to our designated crumb
            if dist2DToCrumb > 0.8 then
                myHumanoid.AutoRotate = true
                myHumanoid:MoveTo(myCrumb.pos)
                
                -- Check for jumps closer ahead of us (scan up to 4 crumbs back)
                local checkJumpIndex = math.max(1, idealCrumbIndex - 3)
                for i = idealCrumbIndex, checkJumpIndex, -1 do
                    if TargetBreadcrumbs[i] and TargetBreadcrumbs[i].jump then
                        local crumbDist = Vector2.new(myRoot.Position.X - TargetBreadcrumbs[i].pos.X, myRoot.Position.Z - TargetBreadcrumbs[i].pos.Z).Magnitude
                        if crumbDist < 3.0 then
                            myHumanoid.Jump = true
                            break
                        end
                    end
                end
            else
                -- We reached our exact spot in the chain. Wait for leader to keep walking.
                myHumanoid.AutoRotate = false
                myHumanoid:MoveTo(myRoot.Position)
                
                -- Look slightly ahead towards where they need to go next
                local lookPos
                if idealCrumbIndex > 1 then
                    lookPos = TargetBreadcrumbs[idealCrumbIndex - 1].pos
                else
                    lookPos = targetPos
                end
                
                local lookTarget = Vector3.new(lookPos.X, myRoot.Position.Y, lookPos.Z)
                if (lookTarget - myRoot.Position).Magnitude > 0.01 then
                    myRoot.CFrame = CFrame.lookAt(myRoot.Position, lookTarget)
                end
            end

        elseif CurrentMode == "vform" then
            local row = math.ceil(altIndexOffset / 2)
            local isLeft = (altIndexOffset % 2 == 1)
            
            -- If we have an odd number of total alts (like 5 or 7), the very last alt in the V
            -- will be alone on their row. We want them in the direct center.
            local isLastRow = (row == math.ceil(TotalAlts / 2))
            local altsInLastRow = (TotalAlts % 2 == 1) and 1 or 2
            
            local xOffset = 0
            if isLastRow and altsInLastRow == 1 then
                -- This alt is completely alone in the final row, put them in the middle
                xOffset = 0
            else
                xOffset = (isLeft and -1 or 1) * (row * 4)
            end
            
            local zOffset = row * 4
            
            local targetPos = (targetRoot.CFrame * CFrame.new(xOffset, 0, zOffset)).Position
            myHumanoid.WalkSpeed = 16 -- Enforce walk speed
            myHumanoid:MoveTo(targetPos)

        elseif CurrentMode == "army" then
            -- Army march: 3 columns, fills row by row behind the leader
            local row = math.floor((altIndexOffset - 1) / 3) + 1
            local colIndex = ((altIndexOffset - 1) % 3) -- 0, 1, or 2
            
            -- Check if this alt is in the final row
            local totalRows = math.ceil(TotalAlts / 3)
            local isLastRow = (row == totalRows)
            local altsInLastRow = (TotalAlts % 3 == 0) and 3 or (TotalAlts % 3)
            
            local col = 0
            if isLastRow and altsInLastRow == 1 then
                -- 1 person alone in the back -> keep them perfectly centered
                col = 0
            elseif isLastRow and altsInLastRow == 2 then
                -- 2 people alone in the back -> center them like a mini row of 2
                col = (colIndex == 0) and -0.5 or 0.5
            else
                -- Normal 3-wide row: Left (-1), Middle (0), Right (1)
                col = colIndex - 1
            end
            
            local xOffset = col * 4
            local zOffset = row * 4
            
            local targetPos = (targetRoot.CFrame * CFrame.new(xOffset, 0, zOffset)).Position
            myHumanoid.WalkSpeed = 16
            myHumanoid:MoveTo(targetPos)

        elseif CurrentMode == "flank" then
            -- Flank: half left, half right. Very wide spread.
            local row = math.ceil(altIndexOffset / 2)
            local isLeft = (altIndexOffset % 2 == 1)
            
            -- If uneven number of alts (e.g. 5, 7), the last person goes direct center in the back
            local isLastRow = (row == math.ceil(TotalAlts / 2))
            local altsInLastRow = (TotalAlts % 2 == 1) and 1 or 2
            
            local xOffset = 0
            if isLastRow and altsInLastRow == 1 then
                xOffset = 0 -- Center
            else
                xOffset = (isLeft and -12 or 12) -- 12 studs out on each side
            end
            
            local zOffset = (row - 1) * 4 -- Start lined up alongside leader, then filter back
            
            local targetPos = (targetRoot.CFrame * CFrame.new(xOffset, 0, zOffset)).Position
            myHumanoid.WalkSpeed = 16
            myHumanoid:MoveTo(targetPos)

        elseif CurrentMode == "swarm" then
            local timeSec = tick()
            local divisor = math.max(1, TotalAlts)
            local angle = (altIndexOffset * (math.pi * 2 / divisor)) + (timeSec * 4)
            local radius = 3 + (altIndexOffset % 2) * 1.5
            local xOffset = math.cos(angle) * radius
            local zOffset = math.sin(angle) * radius
            
            local targetPos = targetRoot.Position + Vector3.new(xOffset, 0, zOffset)
            
            -- Keep AutoRotate ON instead of overriding CFrame so they naturally run along the circle trajectory
            myHumanoid.AutoRotate = true
            
            myHumanoid:MoveTo(targetPos)
            
            -- Alts jump randomly
            if math.random() < 0.05 then
                myHumanoid.Jump = true
            end
            
        elseif CurrentMode == "circlein" or CurrentMode == "circleout" then
            local divisor = math.max(1, TotalAlts)
            -- Give them a fixed spot on the circle based on their index
            local angle = ((altIndexOffset - 1) * (math.pi * 2 / divisor))
            local radius = 8 -- Fixed radius for the circle
            local xOffset = math.cos(angle) * radius
            local zOffset = math.sin(angle) * radius
            
            local targetPos = targetRoot.Position + Vector3.new(xOffset, 0, zOffset)
            
            -- Check if they are already in position
            local distFromTarget = (Vector3.new(targetPos.X, myRoot.Position.Y, targetPos.Z) - myRoot.Position).Magnitude
            
            if distFromTarget > 1 then
                -- Still walking to the spot, let AutoRotate naturally turn them
                myHumanoid.WalkSpeed = 16 -- Enforce walk speed
                myHumanoid.AutoRotate = true
                myHumanoid:MoveTo(targetPos)
            else
                -- Once they reach the spot, lock their rotation inward/outward
                myHumanoid.AutoRotate = false
                myHumanoid:MoveTo(myRoot.Position) -- Stop excessive moving
                
                local lookTarget
                if CurrentMode == "circlein" then
                    -- Face towards the leader
                    lookTarget = Vector3.new(targetRoot.Position.X, myRoot.Position.Y, targetRoot.Position.Z)
                else
                    -- Face away from the leader
                    local awayDir = (myRoot.Position - targetRoot.Position).Unit
                    lookTarget = myRoot.Position + (awayDir * 5)
                    lookTarget = Vector3.new(lookTarget.X, myRoot.Position.Y, lookTarget.Z)
                end
                
                if (lookTarget - myRoot.Position).Magnitude > 0.01 then
                    myRoot.CFrame = CFrame.lookAt(myRoot.Position, lookTarget)
                end
            end

        elseif CurrentMode == "spin" then
            local divisor = math.max(1, TotalAlts)
            -- Give them a fixed spot on the circle based on their index
            local angle = ((altIndexOffset - 1) * (math.pi * 2 / divisor))
            
            -- Calculate radius so they are roughly 3 studs apart on the circumference
            -- Calculate radius so they are separated by 3 studs, but pad the spin radius to be larger.
            local radius = math.max(6, (TotalAlts * 3) / (math.pi * 2))
            
            -- Time-based rotation modifier
            -- 16 studs/sec is normal walk speed. 
            local timeSec = tick()
            local spinSpeed = 16 / radius -- Rads per second to match walk speed
            local currentAngle = angle + (timeSec * spinSpeed)

            local xOffset = math.cos(currentAngle) * radius
            local zOffset = math.sin(currentAngle) * radius
            
            local targetPos = targetRoot.Position + Vector3.new(xOffset, 0, zOffset)
            
            -- Walk along the calculated circle
            myHumanoid.AutoRotate = true
            myHumanoid:MoveTo(targetPos)

