                local bp = Instance.new("BodyPosition")
                bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bp.D = 2000
                bp.P = 50000
                bp.Position = myRoot.Position
                bp.Parent = myRoot
            end
            
            if not myRoot:FindFirstChildOfClass("BodyGyro") then
                local bg = Instance.new("BodyGyro")
                bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
                bg.CFrame = myRoot.CFrame
                bg.Parent = myRoot
            end
        end
        
        print("[Alt Controller] Carpet ON.")
        return
    end
    

    -- UFO
    if cmdLower == "ufo" then
        StopAllActions()
        ApplyModeSetup("ufo")
        CommandLeader = Config.MainAccount
        UpdateFollowTarget()
        
        -- Set up PlatformStand + BodyPosition (exactly like carpet)
        local myCharacter = LocalPlayer.Character
        local myRoot = myCharacter and myCharacter:FindFirstChild("HumanoidRootPart")
        local myHumanoid = myCharacter and myCharacter:FindFirstChildOfClass("Humanoid")
        if myRoot and myHumanoid then
            myHumanoid.PlatformStand = true
            
            if not myRoot:FindFirstChildOfClass("BodyPosition") then
                local bp = Instance.new("BodyPosition")
                bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bp.D = 2000
                bp.P = 50000
                bp.Position = myRoot.Position
                bp.Parent = myRoot
            end
            
            if not myRoot:FindFirstChildOfClass("BodyGyro") then
                local bg = Instance.new("BodyGyro")
                bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
                bg.CFrame = myRoot.CFrame
                bg.Parent = myRoot
            end
        end
        
        print("[Alt Controller] UFO ON.")
        return
    end

    -- ORBIT
    if string.sub(cmdLower, 1, 5) == "orbit" then
        StopAllActions()
        ApplyModeSetup("orbit")
        local argStr = ParseArg(6)
        if argStr == "" then CommandLeader = Config.MainAccount else
            local targetPlayer = FindPlayer(argStr)
            if targetPlayer then CommandLeader = targetPlayer.Name end
        end
        UpdateFollowTarget()
        
        local myCharacter = LocalPlayer.Character
        local myRoot = myCharacter and myCharacter:FindFirstChild("HumanoidRootPart")
        local myHumanoid = myCharacter and myCharacter:FindFirstChildOfClass("Humanoid")
        if myRoot and myHumanoid then
            myHumanoid.PlatformStand = true
            
            if not myRoot:FindFirstChildOfClass("BodyPosition") then
                local bp = Instance.new("BodyPosition")
                bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bp.D = 2000
                bp.P = 50000
                bp.Position = myRoot.Position
                bp.Parent = myRoot
            end
            
            if not myRoot:FindFirstChildOfClass("BodyGyro") then
                local bg = Instance.new("BodyGyro")
                bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
                bg.CFrame = myRoot.CFrame
                bg.Parent = myRoot
            end
        end
        
        print("[Alt Controller] Orbit ON -> " .. tostring(CommandLeader))
        return
    end

    -- TORNADO
    if string.sub(cmdLower, 1, 7) == "tornado" then
        StopAllActions()
        ApplyModeSetup("tornado")
        local argStr = ParseArg(8)
        if argStr == "" then CommandLeader = Config.MainAccount else
            local targetPlayer = FindPlayer(argStr)
            if targetPlayer then CommandLeader = targetPlayer.Name end
        end
        UpdateFollowTarget()
        
        -- Set up tornado physics on the humanoid
        local myCharacter = LocalPlayer.Character
        local myHumanoid = myCharacter and myCharacter:FindFirstChildOfClass("Humanoid")
        if myHumanoid then
            myHumanoid.WalkSpeed = 50
            myHumanoid.HipHeight = 0.5 -- Low enough for quick bounce-back but high enough for Jump to register
        end
        
        print("[Alt Controller] Tornado ON -> " .. tostring(CommandLeader))
        return
    end

    -- HAUNTED
    if string.sub(cmdLower, 1, 7) == "haunted" or string.sub(cmdLower, 1, 6) == "haunt " then
        StopAllActions()
        ApplyModeSetup("haunted")
        local argStr = (cmdLower:find("^haunted")) and ParseArg(8) or ParseArg(7)
        if argStr == "" then CommandLeader = Config.MainAccount else
            local targetPlayer = FindPlayer(argStr)
            if targetPlayer then CommandLeader = targetPlayer.Name end
        end
        UpdateFollowTarget()
        
        -- Reset haunted state
        hauntedPhase = "idle"
        hauntedTimer = math.random() * 5 + 2
        
        print("[Alt Controller] Haunted ON -> " .. tostring(CommandLeader))
        return
    end

    -- STRIKE (dispatched by main account with __idx suffix)
    if string.sub(cmdLower, 1, 6) == "strike" then
        local fullArg = ParseArg(7)
        if fullArg ~= "" then
            -- Parse assigned alt index from the command (format: "playername __idx2")
            local playerName, assignedIdx = string.match(fullArg, "^(.-)%s+__idx(%d+)$")
            if not playerName or playerName == "" then
                -- Fallback: old format without index, default to alt 1
                playerName = string.match(fullArg, "^(.-)%s*$") -- Trim trailing spaces
                assignedIdx = 1
            else
                playerName = string.match(playerName, "^%s*(.-)%s*$") -- Trim whitespace
                assignedIdx = tonumber(assignedIdx)
            end
            
            local targetPlayer = FindPlayer(playerName)
            local altIndexOffset = math.max(1, MyIndex - 1)
            
            if targetPlayer and altIndexOffset == assignedIdx then
                ActiveStrikes[altIndexOffset] = {
                    targetName = targetPlayer.Name,
                    timer = 0,
                    phase = "homing"
                }
                print("[Alt Controller] I am striking: " .. targetPlayer.Name)
            end
        end
        return
    end

    print("[Alt Controller] Received command:", cmdLower)
end

